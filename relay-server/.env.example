PORT=18087
PAIR_TTL_MS=900000
MAX_BODY_BYTES=16384
MAX_MESSAGE_BYTES=1048576
MAX_PAIR_REQUESTS_PER_WINDOW=30
RATE_LIMIT_WINDOW_MS=60000
REQUEST_TIMEOUT_MS=15000
RELAY_BUILD=dev
TRUST_PROXY=true
REQUIRE_ORIGIN=false

# Optional comma-separated WS Origin allowlist.
# Leave empty to allow non-browser clients with no Origin header.
ORIGIN_ALLOWLIST=

# Optional CORS for browser POST /pair calls.
# Leave empty to disable CORS headers.
CORS_ALLOW_ORIGIN=

